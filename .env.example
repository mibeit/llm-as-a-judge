# --- Anthropic (when --provider anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
JUDGEX_MODEL=claude-sonnet-4-6

# --- OpenAI-compatible (when --provider openai_compatible) ---
# For OpenAI proper:
#   JUDGEX_API_KEY=sk-...
#   JUDGEX_MODEL=gpt-4o-mini
# For a self-hosted OpenAI-compatible endpoint (vLLM, Ollama, TGI, university cluster):
#   JUDGEX_BASE_URL=https://your-cluster.example/v1
#   JUDGEX_API_KEY=...optional, falls back to "not-required" if the server doesnt enforce auth
#   JUDGEX_MODEL=llama-3.1-70b-instruct        # or whatever the server serves

# JUDGEX_PROVIDER=anthropic | openai_compatible | mock   # default for get_provider() without args
